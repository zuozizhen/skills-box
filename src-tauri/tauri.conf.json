{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skills-box",
  "version": "0.1.1-rc.1",
  "identifier": "com.zuozizhen.skillsbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Skills Box",
        "width": 320,
        "height": 550,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "hiddenTitle": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false
      },
      {
        "label": "dashboard",
        "title": "",
        "width": 1024,
        "height": 820,
        "minWidth": 860,
        "minHeight": 640,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "hiddenTitle": true,
        "skipTaskbar": false,
        "visible": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zuozizhen/skills-box/releases/latest/download/latest.json"
      ],
      "pubkey": "__TAURI_UPDATER_PUBKEY__"
    }
  }
}
